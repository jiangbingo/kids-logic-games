# 数据库配置
DATABASE_URL=postgresql://gamesuser:gamespass@localhost:5432/gamesdb

# Redis配置
REDIS_URL=redis://localhost:6379

# 服务器配置
PORT=3000
NODE_ENV=production

# CORS配置
CORS_ORIGIN=*

# API配置
API_VERSION=v1
API_PREFIX=/api

# 安全配置
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# 日志配置
LOG_LEVEL=info

# 加密密钥（用于token等，如果需要）
JWT_SECRET=your-secret-key-change-in-production

# 会话配置
SESSION_SECRET=your-session-secret-change-in-production